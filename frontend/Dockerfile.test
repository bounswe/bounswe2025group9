FROM node:18-alpine

WORKDIR /app

# Copy package files
COPY package*.json ./

# Install dependencies
RUN npm ci

# Copy source code
COPY . .

# Install Chrome and ChromeDriver for testing
RUN apk add --no-cache \
    chromium \
    chromium-chromedriver

ENV CHROME_BIN=/usr/bin/chromium-browser
ENV CHROMEDRIVER_PATH=/usr/bin/chromedriver

CMD ["npm", "test"]
